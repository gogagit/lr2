<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.photogallery.controllers.GalleryController"
            styleClass="root-pane">

    <top>
        <VBox spacing="6" styleClass="top-panel">
            <children>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Альбом впечатлений" styleClass="title-label"/>

                        <Button text="Папка" onAction="#onChooseFolder" styleClass="primary-button"/>
                        <Button text="Открыть" onAction="#onLoadAlbum" styleClass="secondary-button"/>
                        <Button text="Сохр. альбом" onAction="#onSaveAlbum" styleClass="secondary-button"/>
                        <Button text="PNG" onAction="#onSaveCurrentSlide" styleClass="secondary-button"/>
                    </children>
                </HBox>

                <HBox spacing="7" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Формат:" styleClass="info-label"/>
                        <ComboBox fx:id="formatSelector" onAction="#onFormatChanged" prefWidth="95"/>

                        <Label text="Интервал:" styleClass="info-label"/>
                        <TextField fx:id="intervalInput" prefWidth="70"/>

                        <Button text="OK" onAction="#onApplyInterval" styleClass="secondary-button"/>

                        <Label text="Анимация:" styleClass="info-label"/>
                        <ComboBox fx:id="animationSelector" prefWidth="145"/>

                        <Label text="Длит.:" styleClass="info-label"/>
                        <TextField fx:id="animationDurationInput" prefWidth="65"/>
                    </children>
                </HBox>

                <Label fx:id="folderLabel"
                       text="Папка не выбрана"
                       styleClass="path-label"
                       wrapText="true"/>

            </children>

            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="slidePane" styleClass="viewer-panel">
            <children>
                <ImageView fx:id="displayArea"
                           fitWidth="900"
                           fitHeight="385"
                           preserveRatio="true"/>

                <Label fx:id="overlayTextLabel"
                       styleClass="overlay-text-label"
                       wrapText="true"
                       maxWidth="680"
                       StackPane.alignment="TOP_CENTER"/>

                <Label fx:id="stickerLabel"
                       styleClass="sticker-label"
                       StackPane.alignment="CENTER"/>

                <Label fx:id="emotionLabel"
                       styleClass="emotion-label"
                       StackPane.alignment="BOTTOM_RIGHT"/>
            </children>

            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>
        </StackPane>
    </center>

    <bottom>
        <VBox spacing="6" styleClass="bottom-panel">
            <children>

                <HBox spacing="7" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Реакция:" styleClass="info-label"/>
                        <ComboBox fx:id="emotionSelector"
                                  onAction="#onEmotionChanged"
                                  prefWidth="145"/>

                        <Label text="Текст:" styleClass="info-label"/>
                        <TextField fx:id="overlayInput"
                                   prefWidth="230"
                                   promptText="Надпись на слайде"/>

                        <Label text="Стикер:" styleClass="info-label"/>
                        <ComboBox fx:id="stickerSelector" prefWidth="75"/>

                        <Label text="Рисунок:" styleClass="info-label"/>
                        <ComboBox fx:id="shapeSelector" prefWidth="105"/>

                        <Button text="Прикрепить" onAction="#onApplyOverlay" styleClass="secondary-button"/>
                    </children>
                </HBox>

                <HBox spacing="7" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Заметка:" styleClass="info-label"/>

                        <TextArea fx:id="noteArea"
                                  prefRowCount="2"
                                  prefHeight="44"
                                  prefWidth="690"
                                  promptText="Заметка хранится именно у текущего слайда"/>

                        <Button text="Сохранить" onAction="#onSaveNote" styleClass="secondary-button"/>
                    </children>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="counterLabel"
                               text="Нет слайдов"
                               styleClass="counter-label"
                               minWidth="135"/>

                        <ProgressBar fx:id="progressBar"
                                     prefWidth="360"
                                     progress="0.0"/>

                        <Button text="◀" onAction="#onPreviousClick" styleClass="player-button"/>
                        <Button fx:id="playButton" text="▶" onAction="#onStartSlideshow" styleClass="player-button"/>
                        <Button fx:id="stopButton" text="■" onAction="#onStopSlideshow" styleClass="player-button" disable="true"/>
                        <Button text="▶▶" onAction="#onNextClick" styleClass="player-button"/>

                        <Button text="Левее" onAction="#onMoveSlideLeft" styleClass="secondary-button"/>
                        <Button text="Правее" onAction="#onMoveSlideRight" styleClass="secondary-button"/>
                    </children>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Button text="Музыка" onAction="#onChooseMusic" styleClass="secondary-button"/>
                        <Button text="Играть" onAction="#onPlayMusic" styleClass="secondary-button"/>
                        <Button text="Стоп" onAction="#onStopMusic" styleClass="secondary-button"/>

                        <Label fx:id="musicLabel"
                               text="Музыка не выбрана"
                               styleClass="path-label"
                               wrapText="true"/>
                    </children>
                </HBox>

            </children>

            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>
        </VBox>
    </bottom>

</BorderPane>